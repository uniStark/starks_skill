# starks configuration — copy to .env and adjust, or export in your shell.
# All optional: unset values fall back to sensible defaults or skip gracefully.

# Strongest model for parallel sub-agents (PM-dispatched workers).
# Examples: Claude "opus"; a strong Codex model such as a "gpt-5"-class model.
STARKS_AGENT_MODEL=

# Model used for cross-model review on the OTHER engine.
# Examples: same as above.
STARKS_REVIEW_MODEL=

# Project-memory directory (e.g. a subfolder of your Obsidian vault).
# If unset, the memory step is skipped entirely.
# Example: ~/Obsidian/your-vault/starks-skill
STARKS_MEMORY_DIR=

# Optional: a personal writing-style note the memory writer reads first
# so summaries match your voice. If unset, this step is skipped.
# Example: ~/Obsidian/your-vault/style-guide.md
STARKS_STYLE_NOTE=
