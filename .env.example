# starks configuration — copy to .env and adjust, or export in your shell.
# scripts/cross-review.sh reads the reviewer keys below. Exported values win.
# All optional: unset values fall back to sensible defaults or skip gracefully.

# Strongest model for parallel sub-agents (PM-dispatched workers).
# Examples: Claude "opus"; a strong Codex model such as a "gpt-5"-class model.
STARKS_AGENT_MODEL=

# Cross-review reviewer models, one per reviewer engine.
# Used when Codex reviews a Claude-drafted plan (Claude→Codex). Example: gpt-5.5
STARKS_REVIEW_MODEL_CODEX=
# Used when Claude reviews a Codex-drafted plan (Codex→Claude). Example: claude-opus-4-8
STARKS_REVIEW_MODEL_CLAUDE=

# Cross-review timeout in seconds. Enforced by the wrapper's portable watchdog.
STARKS_REVIEW_TIMEOUT_SECONDS=600

# Project-memory directory (e.g. a subfolder of your Obsidian vault).
# Configuring this only enables task-scoped, budgeted read/write opt-in prompts.
# Memory is never read or written automatically; unset skips the option entirely.
# Example: ~/Obsidian/your-vault/starks-skill
STARKS_MEMORY_DIR=

# Optional: a personal writing-style note the memory writer reads first
# so summaries match your voice. If unset, this step is skipped.
# Example: ~/Obsidian/your-vault/style-guide.md
STARKS_STYLE_NOTE=
